# Copy to .env for local runs. Never commit the real .env (it's gitignored).

# The public GitHub repo (owner/name) to triage recent Actions failures for.
CI_TRIAGE_TARGET_REPO=cyntra360hub/agent-pulse

# How many of the most recent workflow runs to inspect.
CI_TRIAGE_LOOKBACK=20

# Optional: a GitHub token to raise the API rate limit from 60/hr
# (anonymous) to 5000/hr. Not required for a handful of runs. In CI, the
# workflow's own automatic GITHUB_TOKEN is used automatically if this is
# left blank (see cli/config.py).
CI_TRIAGE_GITHUB_TOKEN=

# Optional: AiOps Enabler reporting. Leave both blank to run fully offline
# with no phone-home. Set both to enable signed task-event reporting.
CI_TRIAGE_AGENT_KEY_ID=
CI_TRIAGE_AGENT_SECRET=
CI_TRIAGE_BASE_URL=https://api.aiopsenabler.com
